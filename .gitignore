.DS_Store
__pycache__/
*.py[cod]

# Local/generated dashboard output. These files include personal usage data,
# session titles, thread IDs, timestamps, and local filesystem paths.
codex_analytics_dashboard.html
codex_analytics_data.json
codex_usage_dashboard.html
codex_usage_data.json

# App/runtime outputs
*.log
*.pid
*.url

# Local Claude worktrees and generated assistant artifacts
.claude/

# Local environments and secrets
.env
.env.*
.venv/
venv/
node_modules/
*.tgz
npm-debug.log*

# Raw Codex/session exports should never be committed.
.codex/
*.jsonl
*.sqlite
*.sqlite3
*.db

# Privacy-preserving snapshots are smaller than raw Codex logs, but still
# personal analytics data and should stay out of public repos.
Codex Analytics/
CodexAnalytics/
codex-analytics/
codex-analytics-snapshots/
/devices/
